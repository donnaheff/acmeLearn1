# Public, browser-safe values (the anon key is designed to be exposed client-side; RLS enforces access).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_SITE_URL=https://learn.example.com
# Set to "true" only for the build that gets bundled into the Capacitor Android/iOS shells.
NEXT_PUBLIC_MOBILE_APP=false
